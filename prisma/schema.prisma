// Prisma schema — mirrors the `cilm` template (custom output + Accelerate),
// with models adapted for audio playback.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  // "native" for local dev; the rhel target is Vercel's serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — used by the app at runtime
  directUrl = env("DIRECT_URL") // unpooled — used by Prisma Migrate
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
}

// One row per (user, collection) — the single track a user is currently on in
// that collection, and how far in. Playing a different track in the same
// collection overwrites this row. Powers "Jump back in" and resume.
model TrackProgress {
  id             String   @id @default(uuid())
  email          String
  collectionSlug String
  trackSlug      String
  title          String
  hue            Int      @default(210)
  positionSec    Int
  durationSec    Int
  updatedAt      DateTime @updatedAt

  @@unique([email, collectionSlug])
  @@index([email, updatedAt])
}
